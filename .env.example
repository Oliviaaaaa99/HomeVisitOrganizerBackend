# Copy to .env and source it for local dev. Or just use the Makefile targets.

# user-svc
HTTP_ADDR=:8080
DATABASE_URL=postgres://hvo:hvo_dev@localhost:5432/hvo?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# External APIs (not needed for v0 demo — services use stubs until configured)
# ANTHROPIC_API_KEY=        # ranking-svc: enables LLM-as-ranker. Falls back
                            # to rule-based scoring when unset.
# ANTHROPIC_MODEL=          # ranking-svc: optional override. Default is
                            # claude-haiku-4-5-20251001.
# GOOGLE_MAPS_API_KEY=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=
# GOOGLE_OAUTH_CLIENT_ID=
